# ──────────────────────────────────────────────
# gabiOS — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ──────────────────────────────────────────────

# ── IA / LLMs ──────────────────────────────────
ANTHROPIC_API_KEY=           # Claude API (anthropic.com)
OPENAI_API_KEY=              # Embeddings text-embedding-3-small

# ── Banco de dados (Drizzle + Supabase) ────────
# Connection string completa — Supabase → Settings → Database → Connection string (URI)
# Use a "Transaction pooler" URL para ambientes serverless (Vercel, Next.js route handlers)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── Supabase (client SDK) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=       # Settings → API → service_role (NUNCA expor no cliente)

# ── ChromaDB (módulo legado de chat/docs) ──────
CHROMA_URL=http://localhost:8000

# ── Prisma (módulo legado de chat/docs) ────────
# Manter enquanto o módulo de chat/pasta ainda usa SQLite
# DATABASE_URL_PRISMA=file:./prisma/dev.db
