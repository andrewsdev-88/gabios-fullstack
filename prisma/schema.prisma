generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Folder {
  id               String     @id @default(cuid())
  clientName       String
  sector           String?
  notes            String?
  contextSummary   String?    // JSON resumido do contexto
  contextSummaryAt DateTime?  // Data da última geração do resumo
  createdAt        DateTime   @default(now())
  documents        Document[]
  messages         Message[]
}

model Document {
  id        String   @id @default(cuid())
  folderId  String
  fileName  String
  fileType  String   // pdf | md | txt
  status    String   // processing | ready | error
  errorMsg  String?
  createdAt DateTime @default(now())
  folder    Folder   @relation(fields: [folderId], references: [id])

  @@index([folderId])
}

model Message {
  id        String   @id @default(cuid())
  folderId  String
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())
  folder    Folder   @relation(fields: [folderId], references: [id])

  @@index([folderId])
}
