# ──────────────────────────────────────────────────────────
# gabios — variáveis de ambiente
# Copie para .env.local e preencha com seus valores reais.
# NUNCA commite .env.local.
# ──────────────────────────────────────────────────────────

# Banco relacional — SQLite local via Prisma
DATABASE_URL=file:./prisma/dev.db

# Supabase — usado EXCLUSIVAMENTE para pgvector (embeddings)
# Obtenha em: https://supabase.com → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Anthropic — modelo de linguagem principal (Claude)
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — embeddings (text-embedding-3-small)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
